# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies (recursive to catch sub-projects like remotion/node_modules)
node_modules/
/jspm_packages/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage
/.nyc_output

# Next.js
/.next/
/out/

# Production
/build
dist/

# OS-specific files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini

# Miscellaneous
*.pem
*.key
*.pub

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment files (sensitive keys)
.env*
.env.local
.env.development.local
.env.test.local
.env.production.local

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# IDEs and Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Claude Code
.claude/

# Remotion rendered output (regenerate with `cd remotion && npm run render`)
# Uncomment if you prefer not to track large video files:
# public/*-bg.webm
# public/*-bg.mp4
